    }

    val outputFileLabel = JLabel("Output files: not created yet").apply {
        font = Font(Font.SANS_SERIF, Font.PLAIN, 13)
        foreground = Color(66, 73, 92)
    }

    val chooseButton = JButton("Choose Excel File")
    val sampleButton = JButton("Load Default File")
    val exportExcelButton = JButton("Export Excel")
    val exportPdfButton = JButton("Export PDF")
    stylePrimaryButton(chooseButton, Color(21, 115, 71), Color(30, 43, 66))
    stylePrimaryButton(sampleButton, Color(230, 236, 245), Color(30, 43, 66))
    stylePrimaryButton(exportExcelButton, Color(38, 132, 255), Color(30, 43, 66))
    stylePrimaryButton(exportPdfButton, Color(217, 48, 37), Color(30, 43, 66))
    exportExcelButton.isEnabled = false
    exportPdfButton.isEnabled = false

    val headerPanel = JPanel(BorderLayout(0, 14)).apply {
        background = Color.WHITE
        border = BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(Color(224, 228, 236)),
            BorderFactory.createEmptyBorder(20, 20, 20, 20)
        )
    }

    val headingBlock = JPanel().apply {
        layout = BoxLayout(this, BoxLayout.Y_AXIS)
        background = Color.WHITE
        add(titleLabel)
        add(Box.createVerticalStrut(6))
        add(subtitleLabel)
        add(Box.createVerticalStrut(12))
        add(selectedFileLabel)
        add(Box.createVerticalStrut(4))
        add(outputFileLabel)
    }

    val actionsPanel = JPanel(FlowLayout(FlowLayout.LEFT, 10, 0)).apply {
        background = Color.WHITE
        add(chooseButton)
        add(sampleButton)
        add(exportExcelButton)
        add(exportPdfButton)
    }

    headerPanel.add(headingBlock, BorderLayout.CENTER)
    headerPanel.add(actionsPanel, BorderLayout.SOUTH)

    val (totalCard, totalValueLabel) = createMetricCard("Total Students", Color(38, 132, 255))
    val (validCard, validValueLabel) = createMetricCard("Valid Records", Color(21, 115, 71))
    val (passCard, passValueLabel) = createMetricCard("Students Passed", Color(0, 153, 129))
    val (failCard, failValueLabel) = createMetricCard("Students Failed", Color(217, 48, 37))

    val summaryPanel = JPanel(GridLayout(1, 4, 12, 0)).apply {
        background = Color(245, 247, 251)
        add(totalCard)
        add(validCard)
        add(passCard)
        add(failCard)
    }

    val table = JTable(buildTableModel(emptyList())).apply {
        rowHeight = 28
        font = Font(Font.SANS_SERIF, Font.PLAIN, 13)
        gridColor = Color(232, 236, 242)
        setShowGrid(true)
        fillsViewportHeight = true
        tableHeader.reorderingAllowed = false
        tableHeader.font = Font(Font.SANS_SERIF, Font.BOLD, 13)
        tableHeader.background = Color(236, 241, 248)
        tableHeader.foreground = Color(32, 40, 61)
        autoCreateRowSorter = true
    }

    val tablePanel = JPanel(BorderLayout(0, 10)).apply {
        background = Color.WHITE
        border = BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(Color(224, 228, 236)),
            BorderFactory.createEmptyBorder(16, 16, 16, 16)
        )
    }

    val tableTitleLabel = JLabel("Student Results").apply {
        font = Font(Font.SANS_SERIF, Font.BOLD, 18)
        foreground = Color(24, 31, 49)
    }

    val tableHintLabel = JLabel("You can sort by clicking a column header.").apply {
        font = Font(Font.SANS_SERIF, Font.PLAIN, 12)
        foreground = Color(96, 103, 122)
    }

    val tableHeaderPanel = JPanel(BorderLayout()).apply {
        background = Color.WHITE
        add(tableTitleLabel, BorderLayout.NORTH)
        add(tableHintLabel, BorderLayout.SOUTH)
    }

    tablePanel.add(tableHeaderPanel, BorderLayout.NORTH)
    tablePanel.add(JScrollPane(table), BorderLayout.CENTER)

    val statusLabel = JLabel("Ready. Choose an Excel file to begin.").apply {
        font = Font(Font.SANS_SERIF, Font.PLAIN, 13)
        foreground = Color(66, 73, 92)
        border = BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(Color(224, 228, 236)),
            BorderFactory.createEmptyBorder(12, 14, 12, 14)
        )
        isOpaque = true
        background = Color.WHITE
    }

    fun clearSummary() {
        totalValueLabel.text = "0"
        validValueLabel.text = "0"
        passValueLabel.text = "0"
        failValueLabel.text = "0"
    }

    fun updateSummary(students: List<Student>) {
        val validStudents = students.filter(::validateStudentMarks)
        totalValueLabel.text = students.size.toString()
        validValueLabel.text = validStudents.size.toString()
        passValueLabel.text = validStudents.count { it.status == "Pass" }.toString()
        failValueLabel.text = validStudents.count { it.status == "Fail" }.toString()
    }

    var loadedStudents: List<Student> = emptyList()
    var loadedInputFile: File? = null
    var outputExcelFile: File? = null
    var outputPdfFile: File? = null

    fun refreshOutputLabel() {
        val excelOutputText = outputExcelFile?.absolutePath ?: "not created"
        val pdfOutputText = outputPdfFile?.absolutePath ?: "not created"
        outputFileLabel.text = "Output files: Excel=$excelOutputText | PDF=$pdfOutputText"
    }

    fun processFile(inputFile: File) {
        try {
            val students = loadStudentsFromExcel(inputFile)
            loadedStudents = students
            loadedInputFile = inputFile
            outputExcelFile = null
            outputPdfFile = null

            table.model = buildTableModel(students)
            table.autoCreateRowSorter = true
            updateSummary(students)
            exportExcelButton.isEnabled = true
            exportPdfButton.isEnabled = true

            selectedFileLabel.text = "Selected file: ${inputFile.absolutePath}"
            refreshOutputLabel()
            statusLabel.text =
                "Loaded ${students.size} student records successfully. Click Export Excel or Export PDF."

            if (students.isEmpty()) {
                JOptionPane.showMessageDialog(
                    frame,
                    "The file was opened, but no student rows were found after the header row.",
                    "No Student Records",
                    JOptionPane.INFORMATION_MESSAGE
                )
            }
        } catch (ex: Exception) {
            loadedStudents = emptyList()
            loadedInputFile = null
            outputExcelFile = null
            outputPdfFile = null
            clearSummary()
            table.model = buildTableModel(emptyList())
            exportExcelButton.isEnabled = false
            exportPdfButton.isEnabled = false
            selectedFileLabel.text = "Selected file: ${inputFile.absolutePath}"
            refreshOutputLabel()
            statusLabel.text = "Could not process the selected file."
            JOptionPane.showMessageDialog(
                frame,
                ex.message ?: "Unknown error while processing the Excel file.",
                "Processing Error",
                JOptionPane.ERROR_MESSAGE
            )
        }
    }

    chooseButton.addActionListener {
        val fileChooser = JFileChooser().apply {
            dialogTitle = "Select Student Marks Excel File"
            fileFilter = FileNameExtensionFilter("Excel Files", "xlsx")
        }

        if (fileChooser.showOpenDialog(frame) == JFileChooser.APPROVE_OPTION) {
            processFile(fileChooser.selectedFile)
        }
    }

    sampleButton.addActionListener {
        processFile(File("student_marks_15.xlsx"))
    }

    exportExcelButton.addActionListener {
        val inputFile = loadedInputFile
        if (inputFile == null) {
            statusLabel.text = "Load a file before exporting."
            return@addActionListener
        }

        try {
            val resultFile = File(inputFile.parentFile ?: File("."), "student_pass_status.xlsx")
            writeStudentsToExcel(loadedStudents, resultFile)
            outputExcelFile = resultFile
            refreshOutputLabel()
            statusLabel.text = "Excel export created successfully."
        } catch (ex: Exception) {
            statusLabel.text = "Excel export failed."
            JOptionPane.showMessageDialog(
                frame,
                ex.message ?: "Unknown error while exporting the Excel file.",
                "Excel Export Error",
                JOptionPane.ERROR_MESSAGE
            )
        }
    }

    exportPdfButton.addActionListener {
        val inputFile = loadedInputFile
        if (inputFile == null) {
            statusLabel.text = "Load a file before exporting."
            return@addActionListener
        }

        try {
            val resultFile = File(inputFile.parentFile ?: File("."), "student_pass_status.pdf")
            writeStudentsToPdf(loadedStudents, resultFile)
            outputPdfFile = resultFile
            refreshOutputLabel()
            statusLabel.text = "PDF export created successfully."
        } catch (ex: Exception) {
            statusLabel.text = "PDF export failed."
            JOptionPane.showMessageDialog(
                frame,
                ex.message ?: "Unknown error while exporting the PDF file.",
                "PDF Export Error",
                JOptionPane.ERROR_MESSAGE
            )
        }
    }

    val centerPanel = JPanel(BorderLayout(0, 18)).apply {
        background = Color(245, 247, 251)
        add(summaryPanel, BorderLayout.NORTH)
        add(tablePanel, BorderLayout.CENTER)
    }

    root.add(headerPanel, BorderLayout.NORTH)
    root.add(centerPanel, BorderLayout.CENTER)
    root.add(statusLabel, BorderLayout.SOUTH)

    frame.contentPane = root
    frame.minimumSize = Dimension(980, 620)
    frame.setSize(1080, 680)
    frame.setLocationRelativeTo(null)
    frame.defaultCloseOperation = JFrame.EXIT_ON_CLOSE
    frame.isVisible = true
}

fun main() {
    SwingUtilities.invokeLater(::createAndShowUi)
}
